<% content_for(:title) { "OpenSwarm — Worktree Graph" } %>
<% content_for :head do %>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/xterm@5.5.0/css/xterm.min.css">
<% end %>

<div class="w-full h-screen flex flex-col overflow-hidden"
     data-controller="graph-keyboard theme web-terminal"
     data-theme-target="root"
     data-graph-keyboard-selected-value="<%= @selected_id %>"
     data-graph-keyboard-repo-value="<%= @selected_repo&.dig(:name) %>"
     data-graph-keyboard-open-project-url-value="<%= open_project_worktrees_path %>"
     data-graph-keyboard-create-url-value="<%= create_worktree_worktrees_path %>"
     data-graph-keyboard-delete-url-value="<%= delete_worktree_worktrees_path %>"
     data-graph-keyboard-open-url-value="<%= open_terminal_worktrees_path %>">

  <%# ═══ Top Bar ═══ %>
  <header class="flex items-center justify-between px-5 py-2.5 border-b border-gray-200 bg-white shrink-0 z-10">
    <div class="flex items-center gap-5">
      <div class="flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-blue-600 animate-soft-pulse"></div>
        <h1 class="text-[13px] font-semibold tracking-wide text-gray-800">
          <span class="text-blue-600">open</span><span class="text-gray-600">swarm</span>
        </h1>
      </div>

      <div class="h-4 w-px bg-gray-200"></div>

      <%# Repo Selector %>
      <div class="flex items-center gap-1.5">
        <% @repos.each do |repo| %>
          <a href="<%= worktrees_path(repo: repo[:name]) %>"
             class="text-[11px] font-mono px-2.5 py-1 rounded-md transition-all duration-150
                    <%= repo[:name] == @selected_repo&.dig(:name) ?
                      'bg-blue-50 text-blue-700 border border-blue-200' :
                      'text-gray-500 hover:text-gray-700 hover:bg-gray-50 border border-transparent' %>">
            <%= repo[:name] %>
            <span class="text-gray-400 ml-0.5">(<%= repo[:worktree_count] %>)</span>
          </a>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-2">
      <span class="text-[10px] text-gray-400 font-mono mr-2">
        <%= @worktrees.length %> worktree<%= @worktrees.length == 1 ? '' : 's' %>
      </span>
      <button type="button"
              class="text-[11px] font-mono px-2.5 py-1 rounded-md border border-blue-200 text-blue-700 bg-blue-50 hover:bg-blue-100 hover:border-blue-300 transition-all duration-150"
              title="Open a git project"
              data-action="click->graph-keyboard#openProjectPicker">
        open project
      </button>
      <button type="button"
              class="text-[11px] font-mono px-2.5 py-1 rounded-md border border-gray-200 text-gray-500 hover:text-gray-700 hover:border-gray-300 hover:bg-gray-50 transition-all duration-150"
              title="Refresh worktrees (r)"
              data-action="click->graph-keyboard#refresh">
        refresh
      </button>
    </div>
  </header>

  <%# ═══ Main Content ═══ %>
  <div class="flex-1 flex min-h-0">

    <%# ═══ Graph Canvas ═══ %>
    <main class="flex-1 relative overflow-auto bg-white" id="graph-canvas"
          data-graph-keyboard-target="canvas">

      <section class="absolute top-4 right-4 z-20 w-[300px] rounded-xl border border-slate-700/70 bg-slate-950/90 backdrop-blur-sm shadow-xl shadow-slate-900/55 p-3 pointer-events-auto">
        <div class="flex items-center justify-between mb-2">
          <h3 class="text-[10px] uppercase tracking-[0.15em] text-slate-300 font-mono">token legend</h3>
          <div class="flex items-center gap-2">
            <span class="text-[9px] text-slate-500 font-mono">max -> 1.00</span>
            <button type="button"
                    class="text-[9px] font-mono uppercase tracking-[0.08em] text-slate-300 border border-slate-700 rounded px-1.5 py-0.5 hover:text-white hover:border-slate-500 transition-colors"
                    data-action="click->graph-keyboard#toggleTokenLegend">
              <span data-graph-keyboard-target="tokenLegendToggleLabel">collapse</span>
            </button>
          </div>
        </div>
        <p class="mb-2 text-[10px] text-slate-400 font-mono" data-graph-keyboard-target="tokenLegendSummary">idle_wt_count: 0 | active_wt_count: 0 | max_tps: 0.0</p>
        <div data-graph-keyboard-target="tokenLegendContent">
          <div class="space-y-1.5" data-graph-keyboard-target="tokenLegendRows"></div>
          <p class="text-[10px] text-slate-500 font-mono" data-graph-keyboard-target="tokenLegendEmpty">
            open a terminal and run opencode to start tracking tokens/s
          </p>
        </div>
      </section>

      <%# Dotted grid background %>
      <div class="absolute inset-0 bg-grid pointer-events-none"></div>

      <div class="relative p-6" style="min-width: <%= @layout[:width] %>px; min-height: <%= @layout[:height] %>px;">
        <%# SVG Edges %>
        <svg class="absolute inset-0 pointer-events-none" preserveAspectRatio="none"
             viewBox="0 0 <%= @layout[:width] %> <%= @layout[:height] %>"
             style="width: <%= @layout[:width] %>px; height: <%= @layout[:height] %>px;">
          <defs>
            <linearGradient id="edge-grad"
                            gradientUnits="userSpaceOnUse"
                            x1="0" y1="0"
                            x2="0" y2="<%= @layout[:height] %>">
              <stop offset="0%" stop-color="#93c5fd" stop-opacity="0.8" />
              <stop offset="50%" stop-color="#93c5fd" stop-opacity="0.5" />
              <stop offset="100%" stop-color="#93c5fd" stop-opacity="0.3" />
            </linearGradient>
          </defs>

          <% @layout[:edges].each do |edge| %>
            <%# Main edge %>
            <path d="<%= edge[:path] %>" fill="none" stroke="url(#edge-grad)" stroke-width="1.5"
                  stroke-linecap="round" />
          <% end %>
        </svg>

        <%# Worktree Nodes %>
        <% @layout[:nodes].each do |node_data| %>
          <% wt = node_data[:worktree] %>
          <div class="absolute group"
               style="left: <%= node_data[:x] %>px; top: <%= node_data[:y] %>px; width: <%= node_data[:width] %>px;">
            <button type="button"
                    class="w-full cursor-pointer transition-all duration-200 ease-out focus:outline-none"
                    data-action="click->graph-keyboard#selectNode dblclick->graph-keyboard#openNodeTerminal"
                    data-node-id="<%= wt.id %>"
                    data-path="<%= wt.path %>"
                    data-formatted-path="<%= format_path(wt.path) %>"
                    data-branch="<%= wt.branch %>"
                    data-dirty="<%= wt.dirty %>"
                    data-state="<%= wt.state %>"
                    data-ahead="<%= wt.ahead %>"
                    data-behind="<%= wt.behind %>"
                    data-head-short="<%= short_hash(wt.head) %>"
                    data-badge-class="<%= node_state_badge_class(wt.state) %>"
                    title="Click to select, double-click to open terminal"
                    data-graph-keyboard-target="node">
              <div class="rounded-xl border px-4 py-3 transition-all duration-200 ease-out
                         bg-white/95 backdrop-blur-sm
                         hover:-translate-y-0.5 hover:shadow-lg
                         <%= wt.dirty ? 'node-glow-dirty border-red-300 bg-red-50/40' :
                             wt.parent_branch.nil? ? 'node-glow border-amber-300 bg-amber-50/35' :
                             'node-glow border-slate-200 hover:border-slate-300' %>">

              <%# Branch name %>
              <div class="flex items-center justify-between gap-2">
                <span class="text-[12px] font-medium text-gray-800 truncate font-mono tracking-tight">
                  <%= wt.branch %>
                </span>
                <div class="flex items-center gap-1.5 shrink-0">
                  <% if wt.dirty %>
                    <span class="w-1.5 h-1.5 rounded-full bg-red-500 animate-soft-pulse"></span>
                  <% end %>
                  <% if wt.parent_branch.nil? %>
                    <span class="text-[9px] text-amber-600 font-mono">root</span>
                  <% end %>
                </div>
              </div>

              <%# Status row — separate line %>
              <div class="flex items-center gap-2 mt-1.5">
                <span class="text-[10px] px-1.5 py-0.5 rounded-md border font-mono leading-none
                             <%= node_state_badge_class(wt.state) %>">
                  <%= wt.state %>
                </span>
                <% if wt.ahead > 0 %>
                  <span class="text-[10px] text-emerald-600 font-mono">+<%= wt.ahead %></span>
                <% end %>
                <% if wt.behind > 0 %>
                  <span class="text-[10px] text-amber-600 font-mono">-<%= wt.behind %></span>
                <% end %>
              </div>
              </div>
            </button>

            <button type="button"
                    class="node-create-btn absolute left-1/2 top-full w-8 h-8 rounded-full
                           border border-blue-300 bg-white/95 text-blue-600 text-[18px] leading-none
                           flex items-center justify-center shadow-lg shadow-blue-200/50
                           transition-all duration-200 ease-out"
                    title="Create child worktree"
                    data-action="click->graph-keyboard#createFromNode"
                    data-parent-id="<%= wt.id %>"
                    data-parent-branch="<%= wt.branch %>">
              +
            </button>
          </div>
        <% end %>

        <% if @worktrees.empty? %>
          <div class="flex items-center justify-center h-80">
            <div class="text-center">
              <div class="w-12 h-12 mx-auto mb-4 rounded-xl bg-gray-50 border border-gray-200 flex items-center justify-center">
                <svg class="w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                </svg>
              </div>
              <p class="text-gray-500 text-sm font-mono mb-1">no worktrees found</p>
              <p class="text-gray-400 text-[11px] font-mono">
                press <kbd class="px-1.5 py-0.5 bg-gray-100 rounded border border-gray-200 text-gray-500 text-[10px]">a</kbd> to create one
              </p>
            </div>
          </div>
        <% end %>
      </div>
    </main>

    <%# ═══ Right Sidebar ═══ %>
    <aside class="w-[320px] shrink-0 border-l border-gray-200 bg-gray-50 flex flex-col overflow-y-auto">

      <%# ─── Status Overview ─── %>
      <div class="p-4 border-b border-gray-200">
        <h3 class="text-[10px] uppercase tracking-[0.15em] text-gray-400 mb-3 font-mono">overview</h3>
        <div class="grid grid-cols-3 gap-2">
          <div class="text-center py-2.5 px-2 rounded-lg bg-white border border-gray-200">
            <div class="text-base font-semibold text-gray-800 font-mono leading-none mb-1"><%= @worktrees.length %></div>
            <div class="text-[9px] text-gray-400 font-mono uppercase tracking-wider">total</div>
          </div>
          <div class="text-center py-2.5 px-2 rounded-lg bg-white border border-gray-200">
            <div class="text-base font-semibold text-emerald-600 font-mono leading-none mb-1"><%= @worktrees.count { |wt| !wt.dirty } %></div>
            <div class="text-[9px] text-gray-400 font-mono uppercase tracking-wider">clean</div>
          </div>
          <div class="text-center py-2.5 px-2 rounded-lg bg-white border border-gray-200">
            <div class="text-base font-semibold text-red-500 font-mono leading-none mb-1"><%= @worktrees.count(&:dirty) %></div>
            <div class="text-[9px] text-gray-400 font-mono uppercase tracking-wider">dirty</div>
          </div>
        </div>
      </div>

      <%# ─── Selected Worktree Details ─── %>
      <div class="p-4 border-b border-gray-200" data-graph-keyboard-target="details">
        <div class="flex items-center justify-between mb-3">
          <h3 class="text-[10px] uppercase tracking-[0.15em] text-gray-400 font-mono">details</h3>
          <span class="text-[10px] px-1.5 py-0.5 rounded-md border font-mono <%= node_state_badge_class(@selected_node&.state) %>"
                data-graph-keyboard-target="detailsState"><%= @selected_node&.state || "n/a" %></span>
        </div>

        <dl class="space-y-2.5">
          <div class="flex items-start gap-3">
            <dt class="text-[11px] text-gray-400 w-12 shrink-0 font-mono">branch</dt>
            <dd class="text-[12px] text-gray-800 font-medium font-mono"
                data-graph-keyboard-target="detailsBranch"><%= @selected_node&.branch || "-" %></dd>
          </div>
          <div class="flex items-start gap-3">
            <dt class="text-[11px] text-gray-400 w-12 shrink-0 font-mono">path</dt>
            <dd class="text-[11px] text-gray-500 break-all font-mono leading-relaxed"
                data-graph-keyboard-target="detailsPath"><%= @selected_node ? format_path(@selected_node.path) : "-" %></dd>
          </div>
          <div class="flex items-start gap-3">
            <dt class="text-[11px] text-gray-400 w-12 shrink-0 font-mono">HEAD</dt>
            <dd class="text-[11px] text-gray-500 font-mono"
                data-graph-keyboard-target="detailsHead"><%= @selected_node ? short_hash(@selected_node.head) : "-" %></dd>
          </div>
          <div class="flex items-center gap-4">
            <div class="flex items-center gap-2">
              <span class="text-[11px] text-gray-400 font-mono">dirty</span>
              <span class="flex items-center gap-1">
                <span class="w-1.5 h-1.5 rounded-full <%= @selected_node&.dirty ? 'bg-red-500' : 'bg-emerald-500' %>"
                      data-graph-keyboard-target="detailsDirtyDot"></span>
                <span class="text-[11px] font-mono <%= @selected_node&.dirty ? 'text-red-600' : 'text-emerald-600' %>"
                      data-graph-keyboard-target="detailsDirtyText"><%= @selected_node&.dirty ? "yes" : "no" %></span>
              </span>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-[11px] font-mono">
                <span class="text-gray-400">ahead</span>
                <span class="text-emerald-600 ml-1" data-graph-keyboard-target="detailsAhead"><%= @selected_node&.ahead || 0 %></span>
              </span>
              <span class="text-[11px] font-mono">
                <span class="text-gray-400">behind</span>
                <span class="text-amber-600 ml-1" data-graph-keyboard-target="detailsBehind"><%= @selected_node&.behind || 0 %></span>
              </span>
            </div>
          </div>
        </dl>
      </div>

      <%# ─── Worktree List ─── %>
      <div class="p-4 border-b border-gray-200">
        <h3 class="text-[10px] uppercase tracking-[0.15em] text-gray-400 mb-3 font-mono">worktrees</h3>
        <div class="space-y-0.5">
          <% @worktrees.each do |wt| %>
            <button type="button"
               class="w-full flex items-center gap-2.5 px-2.5 py-2 rounded-lg text-left transition-all duration-150 border border-transparent hover:bg-gray-100"
               data-node-id="<%= wt.id %>"
               data-action="click->graph-keyboard#selectFromList"
               data-graph-keyboard-target="listItem">
               <span class="w-1.5 h-1.5 rounded-full shrink-0
                            <%= wt.dirty ? 'bg-red-500' : 'bg-emerald-500' %>"></span>
               <span class="text-[11px] font-mono truncate text-gray-500" data-node-branch-label>
                 <%= wt.branch %>
               </span>
               <span class="ml-auto flex items-center gap-1.5">
                <% if wt.ahead > 0 %>
                  <span class="text-[10px] text-emerald-600 font-mono">+<%= wt.ahead %></span>
                <% end %>
                <% if wt.behind > 0 %>
                  <span class="text-[10px] text-amber-600 font-mono">-<%= wt.behind %></span>
                 <% end %>
               </span>
            </button>
          <% end %>
        </div>
      </div>

      <%# ─── Actions ─── %>
      <div class="p-4 flex-1">
        <h3 class="text-[10px] uppercase tracking-[0.15em] text-gray-400 mb-3 font-mono">actions</h3>
        <div class="grid grid-cols-2 gap-2 mb-3">
          <button type="button"
                  class="px-2.5 py-1.5 rounded-md border border-blue-300 bg-blue-50 text-blue-700 text-[11px] font-mono hover:bg-blue-100 transition-colors"
                  data-action="click->graph-keyboard#createFromSelected"
                  title="Create worktree from selected (a)">
            create
          </button>
          <button type="button"
                  class="px-2.5 py-1.5 rounded-md border border-red-300 bg-red-50 text-red-700 text-[11px] font-mono hover:bg-red-100 transition-colors"
                  data-action="click->graph-keyboard#deleteSelected"
                  title="Delete selected worktree (d)">
            delete
          </button>
        </div>
        <div class="grid grid-cols-1 gap-0.5">
          <% [
            ["r", "refresh worktrees"],
            ["a", "create worktree"],
            ["o", "open terminal"],
            ["f", "fetch + pull"],
            ["R", "rebase onto parent"],
            ["c", "add + commit"],
            ["p", "push"],
            ["d", "delete worktree"],
            ["m", "merge to parent"],
          ].each do |key, label| %>
            <div class="flex items-center gap-2.5 py-1 group">
              <kbd class="text-[10px] font-mono w-[18px] h-[18px] flex items-center justify-center rounded
                          bg-gray-100 border border-gray-200 text-gray-500 shrink-0
                          group-hover:text-gray-700 group-hover:border-gray-300 transition-colors"><%= key %></kbd>
              <span class="text-[11px] text-gray-500 font-mono group-hover:text-gray-700 transition-colors"><%= label %></span>
            </div>
          <% end %>
        </div>
      </div>

      <%# ─── Footer ─── %>
      <div class="p-3 border-t border-gray-200 mt-auto">
        <div class="flex items-center justify-center gap-4 text-[10px] text-gray-400 font-mono">
          <span><kbd class="text-gray-500">j</kbd>/<kbd class="text-gray-500">k</kbd> navigate</span>
          <span class="text-gray-300">·</span>
          <span><kbd class="text-gray-500">r</kbd> refresh</span>
          <span class="text-gray-300">·</span>
          <span><kbd class="text-gray-500">?</kbd> help</span>
        </div>
      </div>
    </aside>
  </div>

  <% if @error %>
    <div class="fixed bottom-4 left-1/2 -translate-x-1/2 bg-red-50 border border-red-200 rounded-xl px-5 py-3 text-[12px] text-red-700 font-mono shadow-lg z-50">
      <span class="text-red-600 font-semibold mr-2">error</span><%= @error %>
    </div>
  <% end %>

  <div class="hidden fixed inset-0 z-[55] bg-black/35 flex items-center justify-center p-4"
       data-graph-keyboard-target="createModal"
       data-action="click->graph-keyboard#closeDialogBackdrop">
    <form class="w-full max-w-md rounded-xl border border-gray-300 bg-white shadow-xl p-4"
          data-action="submit->graph-keyboard#submitCreate click->graph-keyboard#closeDialogBackdrop">
      <h3 class="text-[13px] font-semibold text-gray-800 font-mono mb-2">create worktree</h3>
      <p class="text-[11px] text-gray-500 font-mono mb-3">
        parent: <span class="text-gray-700" data-graph-keyboard-target="createParent"></span>
      </p>
      <label class="block text-[11px] text-gray-500 font-mono mb-1" for="create-worktree-name">branch name</label>
      <input id="create-worktree-name"
             type="text"
             required
             autocomplete="off"
             class="w-full rounded-md border border-gray-300 px-2.5 py-2 text-[12px] font-mono text-gray-800 focus:outline-none focus:border-blue-400"
             data-graph-keyboard-target="createInput"
             placeholder="feature/my-change" />
      <label class="mt-3 flex items-center gap-2 text-[11px] text-gray-700 font-mono">
        <input type="checkbox" class="rounded border-gray-300" data-graph-keyboard-target="createReplace" />
        replace existing worktree/branch with same name
      </label>
      <div class="mt-4 flex items-center justify-end gap-2">
        <button type="button"
                class="px-2.5 py-1.5 rounded-md border border-gray-300 text-gray-600 text-[11px] font-mono hover:bg-gray-50"
                data-action="click->graph-keyboard#cancelCreate">cancel</button>
        <button type="submit"
                class="px-2.5 py-1.5 rounded-md border border-blue-300 bg-blue-50 text-blue-700 text-[11px] font-mono hover:bg-blue-100">create</button>
      </div>
    </form>
  </div>

  <div class="hidden fixed inset-0 z-[55] bg-black/35 flex items-center justify-center p-4"
       data-graph-keyboard-target="deleteModal"
       data-action="click->graph-keyboard#closeDialogBackdrop">
    <form class="w-full max-w-md rounded-xl border border-gray-300 bg-white shadow-xl p-4"
          data-action="submit->graph-keyboard#submitDelete click->graph-keyboard#closeDialogBackdrop">
      <h3 class="text-[13px] font-semibold text-gray-800 font-mono mb-2">delete worktree</h3>
      <p class="text-[11px] text-gray-500 font-mono mb-1">
        branch: <span class="text-gray-700" data-graph-keyboard-target="deleteBranch"></span>
      </p>
      <p class="text-[11px] text-gray-500 font-mono mb-3">
        dirty: <span class="text-gray-700" data-graph-keyboard-target="deleteDirty"></span>
      </p>
      <label class="flex items-center gap-2 text-[11px] text-gray-700 font-mono">
        <input type="checkbox" class="rounded border-gray-300" data-graph-keyboard-target="deleteForce" />
        force delete if dirty
      </label>
      <div class="mt-4 flex items-center justify-end gap-2">
        <button type="button"
                class="px-2.5 py-1.5 rounded-md border border-gray-300 text-gray-600 text-[11px] font-mono hover:bg-gray-50"
                data-action="click->graph-keyboard#cancelDelete">cancel</button>
        <button type="submit"
                class="px-2.5 py-1.5 rounded-md border border-red-300 bg-red-50 text-red-700 text-[11px] font-mono hover:bg-red-100">delete</button>
      </div>
    </form>
  </div>

  <%# ═══ Terminal overlay (hide/show, PTY stays alive in background) ═══ %>
  <div class="hidden fixed inset-0 z-[60] flex items-end sm:items-center justify-center bg-slate-950/45 backdrop-blur-sm p-0 sm:p-6"
       data-web-terminal-target="panel"
       data-action="click->web-terminal#backdropClose">
    <div class="w-full sm:w-[92vw] sm:max-w-5xl h-[86dvh] sm:h-[78vh] mb-0 sm:mb-4 rounded-t-2xl sm:rounded-2xl overflow-hidden bg-transparent shadow-[0_28px_90px_rgba(15,23,42,0.36)] flex flex-col">
      <div class="h-12 px-4 border-b border-slate-200/80 bg-slate-50/92 backdrop-blur-sm flex items-center gap-3 shrink-0">
        <div class="flex items-center gap-1.5 shrink-0">
          <span class="w-2.5 h-2.5 rounded-full bg-red-400"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-amber-300"></span>
          <span class="w-2.5 h-2.5 rounded-full bg-emerald-400"></span>
        </div>
        <div class="min-w-0 flex-1 text-[11px] text-slate-700 font-mono truncate">
          <span data-web-terminal-target="path"></span>
        </div>
        <div class="ml-auto flex items-center gap-2 text-[10px] font-mono text-slate-600 shrink-0">
          <span class="hidden sm:inline-flex px-2 py-0.5 rounded-md border border-slate-200 bg-white text-slate-500">shell: <span class="ml-1 text-slate-700" data-web-terminal-target="shell"></span></span>
          <span class="inline-flex min-w-20 justify-center px-2 py-0.5 rounded-md border border-slate-200 bg-white text-slate-600">status: <span class="ml-1" data-web-terminal-target="status">idle</span></span>
          <button type="button"
                  class="px-2 py-1 rounded-md border border-slate-300 text-slate-600 hover:text-slate-900 hover:border-slate-400 hover:bg-white transition-colors"
                  data-action="click->web-terminal#closePanel"
                  title="Minimize — press Ctrl+G or click indicator to reopen">minimize</button>
          <button type="button"
                  class="px-2 py-1 rounded-md border border-red-300 text-red-600 hover:text-red-700 hover:border-red-400 hover:bg-red-50 transition-colors"
                  data-action="click->web-terminal#killTerminal"
                  title="Kill terminal session">kill</button>
        </div>
      </div>
      <div class="flex-1 min-h-0 terminal-wrap">
        <div class="w-full h-full overflow-hidden bg-[#0b1220]"
             data-web-terminal-target="terminal"></div>
      </div>
    </div>
  </div>

  <button type="button"
          class="hidden fixed right-4 bottom-4 z-[58] px-3 py-1.5 rounded-full border border-slate-600 bg-slate-900/95 text-slate-200 text-[11px] font-mono shadow-lg shadow-slate-900/60 hover:border-slate-500 hover:text-white transition-colors"
          title="Terminal is running in the background"
          data-web-terminal-target="backgroundIndicator"
          data-action="click->web-terminal#reopenFromIndicator">
    <span class="mr-1.5 text-sky-300" data-web-terminal-target="backgroundSpinner">⠿</span>
    <span data-web-terminal-target="backgroundLabel">terminal idle</span>
  </button>
</div>
