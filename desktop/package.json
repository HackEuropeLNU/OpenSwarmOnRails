{
  "name": "openswarm-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Electron shell for OpenSwarm on Rails",
  "main": "main.js",
  "scripts": {
    "dev": "electron .",
    "build:mac": "electron-builder --mac dmg",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.openswarm.desktop",
    "productName": "OpenSwarm",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
